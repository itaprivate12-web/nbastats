@page "/login"
@using Project.Data
@using System.Diagnostics.Eventing.Reader
@inject UserService UserService
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="login-card">
    <h2> Login </h2>

    <p> Username or Email: </p>
    <input @bind="name" />

    <p> Password: </p>
    <input @bind="password" type="password" />

    <div class="remember-row">
        <input type="checkbox" @bind="rememberMe" />
        <label> Remember Me </label>
    </div>

    <button class="btn btn-primary" @onclick="(() => DoLogin(name, password))"> Login </button>

    @if (IsLoginAttempted && IsLogin)
    {
        Console.WriteLine($"Login successfull ({name}, {password})");

        Thread.Sleep(1000);
        Nav.NavigateTo(uri: "/");
    }
    else if (IsLoginAttempted && !IsLogin)
    {
        <p style="color:red;"> Wrong credentials </p>
    }

</div>

@code {
    public string name = "", password = "";
    public bool IsLogin = false, IsLoginAttempted = false;
    private bool rememberMe = false;
    List<Users> user = new List<Users>();

    async Task DoLogin(string name, string password)
    {
        user = UserService.GetUserByLogin(name, password);

        IsLoginAttempted = true;
        IsLogin = UserService.CheckLogin(name, password);

        if (IsLogin)
        {
            UserService.CurrentUser = user;

            if (rememberMe)
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "userId", user[0].Id.ToString());
            }
        }
    }
}

<style>
    body {
        margin: 0;
        background: #f5f5f5;
        font-family: 'Segoe UI', sans-serif;
    }

    .remember-row input[type="checkbox"] {
        width: auto;
        margin-bottom: 0;
        cursor: pointer;
    }

    .login-card {
        width: 360px;
        margin: 100px auto;
        padding: 25px;
        background: #ffffff;
        border-radius: 10px;
        border: 1px solid #ddd;
        text-align: left;
    }

    .login-card h2 {
        margin-bottom: 20px;
        font-size: 1.5rem;
        color: #333;
    }

    .login-card p {
        margin: 10px 0 5px;
        font-size: 0.9rem;
        color: #555;
    }

    .login-card input {
        width: 100%;
        padding: 8px 10px;
        margin-bottom: 12px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 0.95rem;
    }

    .login-card input:focus {
        outline: none;
        border-color: #007bff;
    }

    .login-card .btn {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        border-radius: 6px;
        border: none;
        font-weight: 500;
        cursor: pointer;
    }

    .login-card .btn:hover {
        background: #0056b3;
    }
</style>