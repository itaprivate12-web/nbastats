@using Project.Data
@inject UserService UserService
@inject NavigationManager Nav

<div class="topbar">

    <div class="name" @onclick="GoHome">
        NBA Stats
        <img src="images/NBA.png" />
    </div>

    <div class="search">

        <div class="search-box">
            <input @bind="search" type="text" placeholder="Search for a Player or a Team... " />

            @if (result.Count > 0)
            {
                <div class="search-dropdown">

                    @foreach (var item in result)
                    {

                        @if (item.IsPlayer)
                        {
                            <div class="search-item" @onclick="(() => GoToPlayer(item.Id))">

                                <img src="@item.ImageUrl" />
                                <p> @item.Name </p>

                            </div>
                        }
                        else
                        {

                            <div class="search-item" @onclick="(() => GoToTeam(item.Id))">

                                <img src="@item.ImageUrl" />
                                <p> @item.Name </p>

                            </div>

                        }

                    }

                </div>

            }


        </div>

        <button class="btn btn-primary" @onclick="DoSearch"> Search </button>




        @if (result.Count == 0 && search != "")
        {
            <div class="search-dropdown">

                <div class="error">
                    <p style="color: red;"> No Player / Team Found </p>
                </div>

            </div>
        }

    </div>

    <div class="sign">
        <button class="btn btn-primary" @onclick="Login"> Login </button>
        <button class="btn btn-primary" @onclick="Register"> Register </button>
    </div>
</div>


@code {
    private string search = "";
    private List<Search> result = new List<Search>();

    void GoHome()
    {
        Nav.NavigateTo("/");
    }
    void DoSearch()
    {
        result = UserService.Search(search);

        Console.WriteLine($"Search for '{search}' returned {result.Count} results");
    }

    void GoToPlayer(int id)
    {
        result.Clear();
        search = "";

        Nav.NavigateTo($"/player/{id}");
    }

    void GoToTeam(int id)
    {
        result.Clear();
        search = "";

        Nav.NavigateTo($"/team/{id}");
    }
    void Login()
    {

    }

    void Register()
    {

    }
}

<style>
    .name {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        /* space between text and image */
        padding: 10px 15px;
        background-color: #1d1f21;
        color: #fff;
        font-weight: bold;
        font-size: 1.2rem;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        user-select: none;
        /* prevents text selection on click */
    }

    .name img {
        width: 30px;
        height: 30px;
        object-fit: contain;
        transition: transform 0.3s ease;
    }

    .name:hover {
        background-color: #333;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }

    .name:hover img {
        transform: scale(1.1);
    }

    .search-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px;
        cursor: pointer;
        /* 👈 shows hand */
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

    .search-item:hover {
        background-color: #e9ecef;
        /* 👈 light hover */
        transform: scale(1.02);
        /* 👈 tiny zoom */
    }

    .search-item img {
        width: 35px;
        height: 35px;
        object-fit: cover;
    }

    .search-item p {
        margin: 0;
    }

    /* --- Top Bar --- */
    .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 20px;
        border: 1px solid black;
        width: 100%;
        box-sizing: border-box;
        background-color: #f8f9fa;
    }

    .topbar .name {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: bold;
    }

    .topbar .name img {
        height: 30px;
    }

    .search-box {
        position: relative;
        flex: 1;
    }

    .search-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        background: white;
        border: 1px solid #ccc;
        z-index: 1000;
    }

    .topbar .sign {
        display: flex;
        gap: 5px;
    }

    .topbar .search {
        display: flex;
        flex: 1;
        gap: 5px;
        align-items: center;
        max-width: 500px;
    }

    .search-box input {
        width: 100%;
        padding: 6px 10px;
        font-size: 16px;
    }
</style>