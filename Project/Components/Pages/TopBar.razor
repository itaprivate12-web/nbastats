@using Project.Data
@using System.Runtime.InteropServices
@inject UserService UserService
@inject LanguageService Lang
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="topbar" dir="@Lang.CurrentDirection">

    <div class="name" @onclick="GoHome">
        NBA Stats
        <img src="images/NBA.png" />
    </div>

    <div class="search">

        <div class="search-box">
            <input placeholder="@Lang.T("SearchBarPlaceholder")" @bind="search" @oninput="AutoSearch" type="text" />
            
            @if (result.Count > 0 && !string.IsNullOrEmpty(search))
            {
                <div class="search-dropdown">

                    @foreach (var item in result)
                    {

                        @if (item.IsPlayer)
                        {
                            <div class="search-item" @onclick="(() => GoToPlayer(item.Id))">

                                <img src="@item.ImageUrl" />
                                <p> @item.Name </p>

                            </div>
                        }
                        else
                        {

                            <div class="search-item" @onclick="(() => GoToTeam(item.Id))">

                                <img src="@item.ImageUrl" />
                                <p> @item.Name </p>

                            </div>

                        }

                    }

                </div>

            }
        </div>

        <button class="btn btn-primary" @onclick="DoSearch"> @Lang.T("Search") </button>

        @if (result.Count == 0 && search != "")
        {
            <div class="search-dropdown">

                <div class="error">
                    <p style="color: red;"> No Player / Team Found </p>
                </div>

            </div>
        }

    </div>

    <div class="sign">

        @if (UserService.CurrentUser != null && UserService.CurrentUser.Count > 0)
        {
            <div class="user" @onclick="() => GoToProfile(UserService.CurrentUser[0].Id)">

                <img src="@UserService.CurrentUser[0].ProfilePicture" class="pfp" />
                <p class="username"> @UserService.CurrentUser[0].UserName </p>
            
            </div>
            <button class="btn btn-secondery" @onclick="Logout"> Logout </button>
        }
        else
        {
            <button class="btn btn-primary" @onclick="Login"> @Lang.T("Login") </button>
            <button class="btn btn-primary" @onclick="Register"> @Lang.T("Register") </button>
        }

        <div class="lang-selector">
            <button class="lang-btn" @onclick="ToggleLangMenu">
                <span class="globe">🌐</span>
            </button>

            @if (showLangMenu)
            {
                <div class="lang-menu">
                    <div class="lang-item" @onclick='() => SetLang("he")'>
                        <span class="flag">🇮🇱</span>
                        <span>עברית</span>
                    </div>

                    <div class="lang-item" @onclick='() => SetLang("en")'>
                        <span class="flag">🇺🇸</span>
                        <span>English</span>
                    </div>
                </div>
            }
        </div>

    </div>
</div>


@code {
    private string search = "";
    private bool showLangMenu = false;
    private List<Search> result = new List<Search>();

    protected override void OnInitialized()
    {
        Nav.RegisterLocationChangingHandler(OnLocationChanging);
        Lang.OnChange += async () => await InvokeAsync(StateHasChanged);
    }

    private ValueTask OnLocationChanging(LocationChangingContext context)
    {
        StateHasChanged();
        return ValueTask.CompletedTask;
    }

    void ToggleLangMenu()
    {
        showLangMenu = !showLangMenu;
    }

    void SetLang(string lang)
    {
        Lang.SetLanguage(lang);
        showLangMenu = false;
    }
    void GoHome()
    {
        Nav.NavigateTo("/");
    }

    void GoToProfile(int Id)
    {
        Nav.NavigateTo($"/profile/{Id}");
    }
    void DoSearch()
    {
        if (string.IsNullOrEmpty(search))
        {
            result.Clear();
            return;
        }

        result = UserService.Search(search);

        Console.WriteLine($"Search for '{search}' returned {result.Count} results");
    }

    void AutoSearch(ChangeEventArgs e)
    {
        search = e.Value?.ToString() ?? "";

        if (string.IsNullOrEmpty(search))
        {
            result.Clear();
            return;
        }

        result = UserService.Search(search);
    }

    void GoToPlayer(int id)
    {
        result.Clear();
        search = "";
        Nav.NavigateTo($"/player/{id}");
    }

    void GoToTeam(int id)
    {
        result.Clear();
        search = "";
        Nav.NavigateTo($"/team/{id}");
    }

    async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "userId");
        UserService.CurrentUser = null;
        Nav.NavigateTo("/");
    }
    void Login() { Nav.NavigateTo("/login"); }
    void Register() { Nav.NavigateTo("/register"); }
}

