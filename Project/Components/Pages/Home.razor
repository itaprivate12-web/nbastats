    }

    .team-card:hover {
        background-color: #e9ecef;
        /* light gray on hover */
        transform: scale(1.02);
        /* tiny zoom effect */
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

    .player-img {
        width: 120px;
        /* smaller image to fit card */
    }

    .player-text h2 {
        font-size: 28px;
        /* smaller title */
    }

    .player-stats p {
        font-size: 20px;
        /* smaller stats text */
    }

    .player-header {
        display: flex;
        align-items: center;
        gap: 25px;
    }

    .team {
        font-size: 18px;
        color: #444;
        margin-top: 8px;
    }
</style>