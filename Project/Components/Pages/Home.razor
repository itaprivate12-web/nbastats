@page "/"
@using Project.Data
@using System.Diagnostics.Eventing.Reader
@using Microsoft.AspNetCore.Components.Web
@inject UserService UserService
@inject LanguageService Lang
@inject NavigationManager Nav

<PageTitle>Home</PageTitle>

<h1 style="color: white;"> space space </h1>

<h1> @Lang.T("TopPlayers") </h1>

<h3 style="color: white;"> space space </h3>

<div class="players-container">

    @foreach (var players in players)
    {
        <div class="player-card" @onclick="(() => GoToPlayer(players.Id))">

            <div class="player-header">
                <img src="@players.ImageUrl" class="player-img">

                <div class="player-text">
                    <h2>@players.Name</h2>
                    <p class="team">@players.TeamName</p>
                </div>
            </div>

            <div class="player-stats">
                <p>Points Per Game: @players.PPG</p>
                <p>Assist Per Game: @players.APG</p>
                <p>Rebounds Per Game: @players.RPG</p>
            </div>

            <button class="fav-btn" @onclick:stopPropagation="true" @onclick="() => ToggleStarPlayer(players.Id)">
                @(UserService.CurrentUser != null && UserService.CurrentUser.Count > 0 &&
            UserService.IsFavoritePlayer(UserService.CurrentUser[0].Id, players.Id) ? "★" : "☆")
            </button>

        </div>
    }
</div>

<h1 style="color: white;"> space space </h1>

<h1> @Lang.T("AllNbaTeams") @teams.Count </h1>

<h3 style="color: white;"> space space </h3>

<div class="teams-container">

    @foreach (var teams in teams)
    {
        <div class="team-card" @onclick="(() => GoToTeam(teams.Id))">
            <img src="@teams.LogoUrl" />
            <p> @teams.TeamName </p>
        </div>
    }

</div>


@code {
    private string search = "";
    private bool isFavorite = false;
    HashSet<int> favPlayers = new();

    private List<Player> players = new List<Player>();
    private List<Teams> teams = new List<Teams>();
    private List<Search> result = new List<Search>();
    protected override void OnInitialized()
    {
        Lang.OnChange += async () => await InvokeAsync(StateHasChanged);
        players = UserService.GetFeaturedPlayers();
        teams = UserService.GetAllTeams();

        Console.WriteLine($"Loaded {teams.Count} teams");
    }

    void GoToTeam(int Id)
    {
        result.Clear();
        search = "";
        Nav.NavigateTo($"/team/{Id}");
    }

    void DoSearch()
    {
        result = UserService.Search(search);

        Console.WriteLine($"Search for '{search}' returned {result.Count} results");
    }

    void GoToPlayer(int id)
    {
        try
        {
            Nav.NavigateTo($"/player/{id}");
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    void ToggleStarPlayer(int playerId)
    {
        if (UserService.CurrentUser == null || UserService.CurrentUser.Count == 0) { return; }

        int userId = UserService.CurrentUser[0].Id;

        if (UserService.IsFavoritePlayer(userId, playerId))
            UserService.RemoveFavoritePlayer(playerId, userId);
        else
            UserService.AddFavoritePlayer(playerId, userId);

        
        StateHasChanged();
    }
}

<style>
    .player-card {
        position: relative;
    }

    .player-card {
        width: 300px;
        background: #e3e3e3;
        border: 2px solid #000;
        padding: 15px;
        margin: 0;

        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .fav-btn {
        position: absolute;
        bottom: 12px;
        right: 12px;

        background: transparent;
        border: none;

        font-size: 26px;
        color: black;

        cursor: pointer;
        transition: all 0.2s ease;
    }

    /* hover */
    .fav-btn:hover {
        transform: scale(1.15);
    }

    /* active (favorited) */
    .fav-btn.active {
        color: gold;
    }

    .teams-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
        /* fit as many as possible per row */
        gap: 10px;
        width: 100%;
        max-width: 1200px;
        /* optional: limits total width */
        margin: 0 auto;
        /* center on page */
        padding: 10px;
    }

    .team-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #e3e3e3;
        border: 1px solid black;
        border-radius: 5px;
        padding: 5px;
        text-align: center;
    }

    .team-card img {
        width: 50px;
        height: 50px;
        object-fit: contain;
        margin-bottom: 5px;
    }

    .team-card p {
        font-size: 10px;
        /* small but readable */
        margin: 0;
    }

    .players-container {
        display: flex;
        flex-wrap: wrap;
        /* allows multiple rows if needed */
        gap: 20px;
        /* spacing between cards */
        justify-content: center;
        /* center the row of cards */
    }

    .player-card {
        width: 300px;
        /* smaller width */
        background: #e3e3e3;
        border: 3px solid black;
        padding: 15px;
        /* smaller padding */
