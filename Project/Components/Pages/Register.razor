@page "/register"
@using Project.Data
@using System.Diagnostics.Eventing.Reader
@inject UserService UserService
@inject NavigationManager Nav

<div class="register-card">
    <h2> Create Account </h2>

    <p> Full Name: </p>
    <input @bind="fullName" />

    <p> User Name: </p>
    <input @bind="userName" />

    <p> Email: </p>
    <input @bind="email" />

    <p> Password: </p>
    <input @bind="password" type="password" />

    @if (IsRegisterAttempted && IsRegister)
    {
        <p style="color:green;"> User created successfully </p>
        Direct();
    }

    <button class="btn btn-primary" @onclick="(() => DoRegister(fullName, userName, email, password))"> Register </button>

    <p class="login-link">
        Already have an account?
        <a href="/login"> Login </a>
    </p>

</div>


@code {
    public string fullName = "", userName = "", email = "", password = "";
    public bool IsRegisterAttempted = false, IsRegister = false;

    void DoRegister(string fullName, string userName, string email, string password)
    {
        IsRegisterAttempted = true;
        UserService.CreateAccount(fullName, userName, email, password);
        IsRegister = true;
    }

    void Direct()
    {
        Thread.Sleep(2000);
        Nav.NavigateTo("/setup");
    }
}

<style>
    /* Page background */
    body {
        margin: 0;
        background: #f5f5f5;
        font-family: 'Segoe UI', sans-serif;
    }

    /* Center card */
    .register-card {
        width: 360px;
        margin: 100px auto;
        padding: 25px;
        background: #ffffff;
        border-radius: 10px;
        border: 1px solid #ddd;
        text-align: left;
    }

    /* Title */
    .register-card h2 {
        margin-bottom: 20px;
        font-size: 1.5rem;
        color: #333;
    }

    /* Labels */
    .register-card p {
        margin: 10px 0 5px;
        font-size: 0.9rem;
        color: #555;
    }

    /* Inputs */
    .register-card input {
        width: 100%;
        padding: 8px 10px;
        margin-bottom: 12px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 0.95rem;
    }

    .register-card input:focus {
        outline: none;
        border-color: #007bff;
    }

    /* Button */
    .register-card .btn {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        border-radius: 6px;
        border: none;
        background: #007bff;
        color: white;
        font-weight: 500;
        cursor: pointer;
    }

    .register-card .btn:hover {
        background: #0056b3;
    }

    /* Login link */
    .login-link {
        margin-top: 15px;
        font-size: 0.9rem;
        color: #555;
    }

    .login-link a {
        color: #007bff;
        text-decoration: none;
    }

    .login-link a:hover {
        text-decoration: underline;
    }
</style>