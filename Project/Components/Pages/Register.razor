@page "/register"
@using Project.Data
@using System.Diagnostics.Eventing.Reader
@inject UserService UserService
@inject LanguageService Lang
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="register-card">
    <h2> @Lang.T("Create") </h2>

    <p> @Lang.T("FullName") </p>
    <input @bind="fullName" />

    <p> @Lang.T("UserName")</p>
    <input @bind="userName" />

    <p> @Lang.T("Email") </p>
    <input @bind="email" />

    <p> @Lang.T("Password") </p>
    <input @bind="password" type="password" />

    <div class="remember-row">
        <input type="checkbox" @bind="rememberMe" />
        <label> @Lang.T("RememberMe") </label>
    </div>

    @if (IsRegisterAttempted && IsRegister)
    {
        <p style="color:green;"> @Lang.T("Usercreated") </p>
        Direct();
    }

    <button class="btn btn-primary" @onclick="(() => DoRegister(fullName, userName, email, password))"> Register
    </button>

    <p class="login-link">
        @Lang.T("Already")
        <a href="/login"> Login </a>
    </p>

</div>


@code {
    public string fullName = "", userName = "", email = "", password = "";
    public bool IsRegisterAttempted = false, IsRegister = false;
    private bool rememberMe = false;

    protected override void OnInitialized()
    {
        Lang.OnChange += async () => await InvokeAsync(StateHasChanged);
    }
    async Task DoRegister(string fullName, string userName, string email, string password)
    {
        var user = UserService.GetUserByLogin(userName, password);

        IsRegisterAttempted = true;
        UserService.CreateAccount(fullName, userName, email, password);
        IsRegister = true;

        if (rememberMe)
        {
            UserService.CurrentUser = UserService.GetUserByLogin(userName, password);

            await JS.InvokeVoidAsync("localStorage.setItem", "userId", user[0].Id.ToString());
        }

        Console.WriteLine($"User ({fullName}, {userName})");
    }

    async Task Direct()
    {
        await Task.Delay(2000);

        Nav.NavigateTo($"/setup/{UserService.CurrentUser[0].Id}");
    }
}

<style>
    body {
        margin: 0;
        background: #f5f5f5;
        font-family: 'Segoe UI', sans-serif;
    }

    .remember-row input[type="checkbox"] {
        width: auto;
        margin-bottom: 0;
        cursor: pointer;
    }

    .register-card {
        width: 360px;
        margin: 100px auto;
        padding: 25px;
        background: #ffffff;
        border-radius: 10px;
        border: 1px solid #ddd;
        text-align: left;
    }

    .register-card h2 {
        margin-bottom: 20px;
        font-size: 1.5rem;
        color: #333;
    }

    .register-card p {
        margin: 10px 0 5px;
        font-size: 0.9rem;
        color: #555;
    }

    /* Inputs */
    .register-card input {
        width: 100%;
        padding: 8px 10px;
        margin-bottom: 12px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 0.95rem;
    }

    .register-card input:focus {
        outline: none;
        border-color: #007bff;
    }

    .register-card .btn {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        border-radius: 6px;
        border: none;
        font-weight: 500;
        cursor: pointer;
    }

    .register-card .btn:hover {
        background: #0056b3;
    }

    .login-link {
        margin-top: 15px;
        font-size: 0.9rem;
        color: #555;
    }

    .login-link a {
        color: #007bff;
        text-decoration: none;
    }

    .login-link a:hover {
        text-decoration: underline;
    }
</style>