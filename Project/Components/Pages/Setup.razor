@page "/setup"
@using Project.Data
@using System.Diagnostics.Eventing.Reader
@inject UserService UserService
@inject NavigationManager Nav

<div class="setup-card">
    <h2> Setup Your Profile </h2>

    <p> Favorite Player: </p>

    <input placeholder="Search Player..." @bind="playerSearch" />
    <div class="search-dropdown">

        @foreach (var item in players.Where(p => p.Name.Contains(playerSearch, StringComparison.OrdinalIgnoreCase)))
        {
            <div class="search-item" @onclick="() => selectPlayer(item)">

                <img src="@item.ImageUrl" />
                <p> @item.Name </p>

            </div>
        }

    </div>

    <p> Favorite Team: </p>

    <input placeholder="Search Team..." @bind="teamSearch" />

    <div class="search-dropdown">

        @foreach (var item in teams.Where(t => t.TeamName.Contains(teamSearch, StringComparison.OrdinalIgnoreCase)))
        {
            <div class="search-item" @onclick="() => selectTeam(item)">

                <img src="@item.LogoUrl" />
                <p> @item.TeamName </p>

            </div>
        }

    </div>

    <p> Choose Profile Pciture: </p>

    @if (selectedPlayer != null)
    {
        <div class="selected-preview">
            <img src="@selectedPlayer.ImageUrl" />
        </div>
    }
    else if (selectedTeam != null)
    {
        <div class="selected-preview">
            <img src="@selectedTeam.LogoUrl" />
        </div>
    }

    <button class="btn btn-primary" @onclick="saveProfile"> Save Picture </button>

</div>

@code {
    List<Player> players = new List<Player>();
    List<Teams> teams = new List<Teams>();

    List<Player> selectedPlayer = new List<Player>();
    List<Teams> selectedTeam = new List<Teams>();

    public string playerSearch = "";
    public string teamSearch = "";

    void selectPlayer(List<Player> player)
    {
        selectedPlayer = player;
        selectedTeam = null;
    }

    void selectTeam(List<Teams> team)
    {
        selectedTeam = team;
        selectedPlayer = null;
    }

    void saveProfile()
    {
        if (UserService.CurrentUser == null)
            return;

        if (selectedPlayer != null)
        {
            UserService.CurrentUser.ProfilePicture = selectedPlayer.ImageUrl;
        }
        else if (selectedTeam != null)
        {
            UserService.CurrentUser.ProfilePicture = selectedTeam;
        }

        Nav.NavigateTo($"/profile/{UserService.CurrentUser.Id}");
    }

}

<style>
    body {
        margin: 0;
        background: #f5f5f5;
        font-family: 'Segoe UI', sans-serif;
    }

    .selected-preview {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
        padding: 10px;
        border: 1px solid #007bff;
        border-radius: 8px;
        background: #f0f8ff;
    }

    .selected-preview img {
        width: 50px;
        height: 50px;
        object-fit: cover;
    }

    .search-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px;
        cursor: pointer;
        /* 👈 shows hand */
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

    .search-item:hover {
        background-color: #e9ecef;
        /* 👈 light hover */
        transform: scale(1.02);
        /* 👈 tiny zoom */
    }

    .search-item img {
        width: 35px;
        height: 35px;
        object-fit: cover;
    }

    .search-item p {
        margin: 0;
    }

    .search-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        background: white;
        border: 1px solid #ccc;
        z-index: 1000;
    }

    .setup-card {
        position: relative;
    }

    /* Center card */
    .setup-card {
        width: 360px;
        margin: 100px auto;
        padding: 25px;
        background: #ffffff;
        border-radius: 10px;
        border: 1px solid #ddd;
        text-align: left;
    }

    /* Title */
    .setup-card h2 {
        margin-bottom: 20px;
        font-size: 1.5rem;
        color: #333;
    }

    /* Labels */
    .setup-card p {
        margin: 10px 0 5px;
        font-size: 0.9rem;
        color: #555;
    }

    /* Inputs */
    .setup-card input {
        width: 100%;
        padding: 8px 10px;
        margin-bottom: 12px;
        border-radius: 6px;
        border: 1px solid #ccc;
        font-size: 0.95rem;
    }

    .setup-card input:focus {
        outline: none;
        border-color: #007bff;
    }

    /* Button */
    .setup-card .btn {
        width: 100%;
        padding: 10px;
        margin-top: 10px;
        border-radius: 6px;
        border: none;
        background: #007bff;
        color: white;
        font-weight: 500;
        cursor: pointer;
    }

    .setup-card .btn:hover {
        background: #0056b3;
    }
</style>