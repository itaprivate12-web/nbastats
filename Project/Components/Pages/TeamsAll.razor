@page "/teams"
@using Project.Data
@using System.Diagnostics.Eventing.Reader
@inject UserService UserService
@inject LanguageService Lang
@inject NavigationManager Nav

<h1> @Lang.T("AllNbaTeams") </h1>

<hr />

<div class="teams-container">

    @foreach (var t in teams)
    {
        <div class="team-card" @onclick="(() => GoToTeam(t.Id))">
            <img src="@t.LogoUrl" />
            <p> @t.TeamName </p>
        </div>
    }

</div>

@code {
    private List<Teams> teams = new List<Teams>();

    protected override void OnInitialized()
    {
        Lang.OnChange += async () => await InvokeAsync(StateHasChanged);
        teams = UserService.GetAllTeams();
    }

    void GoToTeam(int Id)
    {
        Nav.NavigateTo($"/team/{Id}");
    }
}

<style>
    .team-card:hover {
        background-color: #e9ecef;
        /* light gray on hover */
        transform: scale(1.02);
        /* tiny zoom effect */
        transition: background-color 0.2s ease, transform 0.1s ease;
    }

    .teams-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
        /* fit as many as possible per row */
        gap: 10px;
        width: 100%;
        max-width: 1200px;
        /* optional: limits total width */
        margin: 0 auto;
        /* center on page */
        padding: 10px;
    }

    .team-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: #e3e3e3;
        border: 1px solid black;
        border-radius: 5px;
        padding: 5px;
        text-align: center;
    }

    .team-card img {
        width: 50px;
        height: 50px;
        object-fit: contain;
        margin-bottom: 5px;
    }

    .team-card p {
        font-size: 10px;
        /* small but readable */
        margin: 0;
    }

    .team {
        font-size: 18px;
        color: #444;
        margin-top: 8px;
    }
</style>